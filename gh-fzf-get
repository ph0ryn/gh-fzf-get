#!/usr/bin/env bash
set -euo pipefail

owner=
login=
owner_login=
query=
owner_query=
repo_rows=
full_name=
target=
ghq_args=()

for cmd in ghq fzf; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf 'gh fzf-get: %s is required\n' "$cmd" >&2
    exit 1
  fi
done

owner="${1:-}"
if [[ -z "$owner" || "$owner" == -* ]]; then
  login="$(gh api user --jq .login 2>/dev/null)" || {
    printf 'gh fzf-get: failed to get authenticated GitHub user\n' >&2
    exit 1
  }
  owner="$login"
else
  shift
fi

ghq_args=("$@")

owner_query='
  query($owner: String!) {
    repositoryOwner(login: $owner) {
      login
    }
  }
'

query='
  query($owner: String!) {
    repositoryOwner(login: $owner) {
      repositories(
        first: 100
        orderBy: { field: UPDATED_AT, direction: DESC }
      ) {
        nodes {
          nameWithOwner
          isPrivate
          updatedAt
        }
      }
    }
  }
'

owner_login="$(
  gh api graphql \
    -f owner="$owner" \
    -f query="$owner_query" \
    --jq '.data.repositoryOwner.login // ""'
)" || {
  printf 'gh fzf-get: failed to get owner: %s\n' "$owner" >&2
  exit 1
}

if [[ -z "$owner_login" ]]; then
  printf 'gh fzf-get: owner not found: %s\n' "$owner" >&2
  exit 1
fi

repo_rows="$(
  gh api graphql \
    -f owner="$owner" \
    -f query="$query" \
    --jq '
      .data.repositoryOwner.repositories.nodes[]?
      | [
          .nameWithOwner,
          (if .isPrivate then "private" else "public" end),
          .updatedAt
        ]
      | @tsv
    '
)" || {
  printf 'gh fzf-get: failed to get repositories for %s\n' "$owner" >&2
  exit 1
}

if [[ -z "$repo_rows" ]]; then
  printf 'gh fzf-get: no repositories found for %s\n' "$owner" >&2
  exit 1
fi

full_name=$(
  printf '%s\n' "$repo_rows" |
    awk -F '\t' '
      {
        name[NR] = $1
        vis[NR] = $2
        updated[NR] = $3

        if (length($1) > max) {
          max = length($1)
        }
      }

      END {
        for (i = 1; i <= NR; i++) {
          updated_date = substr(updated[i], 1, 10)

          if (vis[i] == "private") {
            label = "\033[1;35mprivate\033[0m"
          } else {
            label = "\033[2;37mpublic \033[0m"
          }

          printf "%s\t%-*s  \033[2;37m%s\033[0m  %s\n", name[i], max, name[i], updated_date, label
        }
      }
    ' |
    fzf \
      --ansi \
      --prompt="repo (${owner})> " \
      --height=40% \
      --layout=reverse \
      --border \
      --delimiter=$'\t' \
      --with-nth=2 |
    cut -f1
) || {
  exit 0
}

[[ -z "$full_name" ]] && {
  exit 0
}

ghq get "${ghq_args[@]}" "git@github.com:${full_name}.git"

target="$(ghq list -p -e "github.com/${full_name}" | head -n 1)"
[[ -z "$target" ]] && exit 1

printf '%s\n' "$target"
